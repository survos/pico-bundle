{
    "name": "survos/pico-bundle",
    "description": "pico-bundle Bundle",
    "keywords": [
        "symfony-ux",
        "symfony"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "twig/twig": "^3.4"
    },
    "require-dev": {
        "symfony/browser-kit": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\PicoBundle\\": "src/"
        }
    }
}
